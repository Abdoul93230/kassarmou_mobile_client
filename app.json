{
  "expo": {
    "name": "Ihambaobab",
    "slug": "ihambaobab",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/adaptive-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "ihambaobab",
    "splash": {
      "image": "./assets/2.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ihambaobab.mobile",
      "associatedDomains": [
        "applinks:ihambaobab.com",
        "applinks:www.ihambaobab.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.ihambaobab.mobile",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "ihambaobab.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.ihambaobab.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "cc2a64e6-a646-43b0-9c43-ba6720c574a0"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/cc2a64e6-a646-43b0-9c43-ba6720c574a0"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
